#!/bin/bash
set -euo pipefail

# Push epub audio files to FileBrowser
# Creates a folder in /downloads/epub-audio/ named after the MP3(s) and uploads there

FILEBROWSER_URL="https://browse.sirius.moonblade.work"
UPLOAD_BASE="/downloads/epub-audio"
SHARE_URL="https://browse.moonblade.work/files/downloads/epub-audio"
TOKEN_FILE="$HOME/.config/pushmd/token"
AUTH_USER="admin"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

show_help() {
    echo "Usage: pushepubaudio <mp3_file_or_directory>"
    echo ""
    echo "Uploads MP3 audio files to FileBrowser epub-audio folder."
    echo ""
    echo "Arguments:"
    echo "  mp3_file_or_directory  - Single MP3 file, or directory containing MP3s"
    echo ""
    echo "The files will be uploaded to /downloads/epub-audio/<folder_name>/"
    echo "  - Single file: folder named after the MP3 (without extension)"
    echo "  - Multiple files: folder named after common prefix of MP3 names"
    echo "  - Directory: folder named after the directory name"
    echo ""
    echo "Options:"
    echo "  -h, --help     Show this help message"
    echo "  --clear-token  Clear saved authentication token"
}

clear_token() {
    if [[ -f "$TOKEN_FILE" ]]; then
        rm "$TOKEN_FILE"
        echo "Token cleared."
    else
        echo "No token file found."
    fi
    exit 0
}

if [[ $# -eq 0 ]] || [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
    show_help
    exit 0
fi

if [[ "$1" == "--clear-token" ]] || [[ "$1" == "--clear-auth" ]]; then
    clear_token
fi

INPUT="$1"

# Collect MP3 files
declare -a MP3_FILES
if [[ -d "$INPUT" ]]; then
    # Directory provided - find all MP3s
    while IFS= read -r -d '' file; do
        MP3_FILES+=("$file")
    done < <(find "$INPUT" -maxdepth 1 -name "*.mp3" -print0 | sort -z)
    
    if [[ ${#MP3_FILES[@]} -eq 0 ]]; then
        echo -e "${RED}Error: No MP3 files found in directory: $INPUT${NC}"
        exit 1
    fi
    
    # Use directory name as folder name
    FOLDER_NAME=$(basename "$INPUT")
elif [[ -f "$INPUT" ]]; then
    if [[ ! "$INPUT" =~ \.mp3$ ]]; then
        echo -e "${RED}Error: File is not an MP3: $INPUT${NC}"
        exit 1
    fi
    MP3_FILES+=("$INPUT")
    # Use filename without extension as folder name
    FOLDER_NAME=$(basename "$INPUT" .mp3)
else
    echo -e "${RED}Error: Path not found: $INPUT${NC}"
    exit 1
fi

# For multiple files, find common prefix
if [[ ${#MP3_FILES[@]} -gt 1 ]]; then
    # Get basenames without extension
    declare -a BASENAMES
    for f in "${MP3_FILES[@]}"; do
        BASENAMES+=("$(basename "$f" .mp3)")
    done
    
    # Find common prefix
    COMMON="${BASENAMES[0]}"
    for name in "${BASENAMES[@]:1}"; do
        while [[ "${name:0:${#COMMON}}" != "$COMMON" ]] && [[ -n "$COMMON" ]]; do
            COMMON="${COMMON:0:$((${#COMMON}-1))}"
        done
    done
    
    # Clean up trailing underscores, numbers, etc.
    COMMON=$(echo "$COMMON" | sed 's/_*[0-9]*$//' | sed 's/_$//')
    
    if [[ -n "$COMMON" ]]; then
        FOLDER_NAME="$COMMON"
    fi
fi

# Sanitize folder name for URL
FOLDER_NAME=$(echo "$FOLDER_NAME" | tr ' ' '_' | sed 's/[^a-zA-Z0-9_.-]/-/g' | sed 's/-\+/-/g' | sed 's/^-\|-$//g')

if [[ -z "$FOLDER_NAME" ]]; then
    FOLDER_NAME="audio_$(date +%Y%m%d_%H%M%S)"
fi

echo "Folder name: $FOLDER_NAME"
echo "Files to upload: ${#MP3_FILES[@]}"

get_new_token() {
    echo "Authenticating via proxy header..." >&2
    local response
    response=$(curl -s -X POST "$FILEBROWSER_URL/api/login" \
        -H "Content-Type: application/json" \
        -H "X-authentik-username: $AUTH_USER" \
        -d '{"username":"","password":""}' \
        -w "\n%{http_code}")
    
    local http_code
    http_code=$(echo "$response" | tail -n1)
    local token
    token=$(echo "$response" | sed '$d')
    
    if [[ "$http_code" != "200" ]]; then
        echo -e "${RED}Error: Authentication failed (HTTP $http_code)${NC}" >&2
        echo -e "${RED}Response: $token${NC}" >&2
        exit 1
    fi
    
    if [[ -z "$token" ]] || [[ "$token" == *"Error"* ]] || [[ "$token" == *"error"* ]]; then
        echo -e "${RED}Error: Invalid token received${NC}" >&2
        exit 1
    fi
    
    mkdir -p "$(dirname "$TOKEN_FILE")"
    echo "$token" > "$TOKEN_FILE"
    chmod 600 "$TOKEN_FILE"
    echo -e "${GREEN}Token saved.${NC}" >&2
    
    echo "$token"
}

load_token() {
    if [[ -f "$TOKEN_FILE" ]]; then
        cat "$TOKEN_FILE"
    else
        get_new_token
    fi
}

create_folder() {
    local token="$1"
    local folder_path="$2"
    
    local response
    response=$(curl -s -w "\n%{http_code}" \
        -X POST "$FILEBROWSER_URL/api/resources${folder_path}/" \
        -H "X-Auth: $token" \
        -H "Content-Type: application/json" \
        -d '{}')
    
    local http_code
    http_code=$(echo "$response" | tail -n1)
    
    # 200, 201, or 409 (already exists) are all OK
    if [[ "$http_code" == "200" ]] || [[ "$http_code" == "201" ]] || [[ "$http_code" == "409" ]]; then
        return 0
    elif [[ "$http_code" == "401" ]]; then
        return 1
    else
        echo -e "${YELLOW}Warning: Folder creation returned HTTP $http_code (may already exist)${NC}"
        return 0
    fi
}

upload_file() {
    local token="$1"
    local local_path="$2"
    local remote_path="$3"
    local attempt=1
    
    while [[ $attempt -le 2 ]]; do
        local filename
        filename=$(basename "$local_path")
        echo "Uploading: $filename"
        
        local response
        response=$(curl -s -w "\n%{http_code}" \
            -X POST "$FILEBROWSER_URL/api/resources${remote_path}?override=true" \
            -H "X-Auth: $token" \
            -H "Content-Type: audio/mpeg" \
            --data-binary @"$local_path")
        
        local http_code
        http_code=$(echo "$response" | tail -n1)
        
        if [[ "$http_code" == "200" ]] || [[ "$http_code" == "201" ]]; then
            echo -e "  ${GREEN}✓${NC}"
            return 0
        elif [[ "$http_code" == "401" ]] && [[ $attempt -eq 1 ]]; then
            echo -e "${YELLOW}Token expired, refreshing...${NC}"
            rm -f "$TOKEN_FILE"
            TOKEN=$(get_new_token)
            token="$TOKEN"
            attempt=2
        else
            echo -e "${RED}Error: Upload failed with HTTP $http_code${NC}"
            local body
            body=$(echo "$response" | sed '$d')
            [[ -n "$body" ]] && echo -e "${RED}Response: $body${NC}"
            return 1
        fi
    done
}

# Main execution
TOKEN=$(load_token)

# Create the folder
FOLDER_PATH="${UPLOAD_BASE}/${FOLDER_NAME}"
echo "Creating folder: $FOLDER_PATH"

if ! create_folder "$TOKEN" "$FOLDER_PATH"; then
    echo -e "${YELLOW}Token expired, refreshing...${NC}"
    rm -f "$TOKEN_FILE"
    TOKEN=$(get_new_token)
    create_folder "$TOKEN" "$FOLDER_PATH"
fi

# Upload each file
FAILED=0
for mp3 in "${MP3_FILES[@]}"; do
    filename=$(basename "$mp3")
    remote_path="${FOLDER_PATH}/${filename}"
    if ! upload_file "$TOKEN" "$mp3" "$remote_path"; then
        FAILED=$((FAILED + 1))
    fi
done

if [[ $FAILED -gt 0 ]]; then
    echo -e "${RED}Failed to upload $FAILED file(s)${NC}"
    exit 1
fi

SHARE_LINK="${SHARE_URL}/${FOLDER_NAME}"
echo ""
echo -e "${GREEN}Uploaded ${#MP3_FILES[@]} file(s) successfully!${NC}"
echo "$SHARE_LINK"

# Copy to clipboard
if command -v pbcopy &> /dev/null; then
    echo "$SHARE_LINK" | pbcopy
    echo "(Copied to clipboard)"
elif command -v xclip &> /dev/null; then
    echo "$SHARE_LINK" | xclip -selection clipboard
    echo "(Copied to clipboard)"
elif command -v wl-copy &> /dev/null; then
    echo "$SHARE_LINK" | wl-copy
    echo "(Copied to clipboard)"
fi
